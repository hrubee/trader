# Binance Futures API keys. Fill the ones you use; NEVER commit this file with real keys (.env is gitignored).
# DEMO/testnet (sandbox) — used when an account has "live": false
BINANCE_DEMO_API_KEY=
BINANCE_DEMO_API_SECRET=
# LIVE/real-money — used when an account has "live": true (also requires LOOP_TRADER_ALLOW_LIVE=1, set by the executor)
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=

# Optional: agent CLI + model the brain wrapper calls (defaults: claude / claude-sonnet-4-6)
# BRAIN_CLI=claude
# BRAIN_MODEL=claude-sonnet-4-6
